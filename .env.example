# ══════════════════════════════════════════════════════════════
# AurumSci — Variáveis de Ambiente
# COPIE este arquivo para .env e preencha os valores reais
# NUNCA commite o .env no git!
# ══════════════════════════════════════════════════════════════

# ── Ambiente ──────────────────────────────────────────────────
ENVIRONMENT=development
# Em produção: ENVIRONMENT=production

# ── Segurança JWT ─────────────────────────────────────────────
# IMPORTANTE: Gere uma chave segura em produção:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=TROQUE_ISSO_POR_UMA_CHAVE_SEGURA_DE_64_CHARS

# ── Banco de dados ────────────────────────────────────────────
DATABASE_URL=sqlite:///./personal_trainer.db
# Em produção usar PostgreSQL:
# DATABASE_URL=postgresql://usuario:senha@host:5432/aurumsci

# ── API Keys ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-XXXXX

# ── Upload ────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# ── Rate Limiting ─────────────────────────────────────────────
MAX_LOGIN_TENTATIVAS=5
JANELA_RATE_LIMIT_SEGUNDOS=60

# ── CORS ──────────────────────────────────────────────────────
# Em produção, adicione seu domínio real:
ALLOWED_ORIGINS=https://aurumsci.com,https://app.aurumsci.com

# ── Email (para notificações) ─────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASSWORD=sua_senha_app

# ── Redis (para blacklist de tokens em produção) ──────────────
# REDIS_URL=redis://localhost:6379/0

# ── Stripe/Pagamento ──────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_XXXXX
# STRIPE_WEBHOOK_SECRET=whsec_XXXXX
